---
import { Image } from "astro:assets";
import heroImage from "../assets/images/acceuil.avif";
---

<div
    class="relative grid h-screen items-end text-beige-claire before:absolute before:inset-0 before:-z-5 before:bg-[linear-gradient(to_top,rgba(0,0,0,0.6)_0%,rgba(102,102,102,0.56)_100%)] after:absolute after:inset-0 after:-z-4 after:bg-marron-fonce/60 after:mix-blend-hard-light"
>
    <div class="relative z-10 px-6 lg:px-16 pb-16">
        <p class="font-corps font-bold text-F5F0E8 text-lg md:text-xl mb-4">
            Noël 2026
        </p>
        <h1
            class="font-titre text-[clamp(3rem,1.5rem+5vw,7rem)] leading-[0.9] tracking-wider mb-6"
        >
            FESTICLOSE
        </h1>
        <p class="font-corps font-medium text-2xl md:text-3xl lg:text-4xl">
            Du 20 au 23 décembre 2026
        </p>
    </div>

    <Image
        class="absolute inset-0 -z-10 size-full object-cover"
        src={heroImage}
        alt="Festival Festiclose - Noël 2026"
        width={1920}
        height={1080}
        loading="eager"
    />
</div>
