---
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import {
    getArtisteById,
    getRepresentations,
} from "../../../backend/backend.mjs";
import heroImage from "../../assets/images/festival.avif";
import ImagePB from "../../components/ImagePB.astro";

const { id } = Astro.params;

const artiste = await getArtisteById(id);

const allRepresentations = await getRepresentations();
const representations = allRepresentations.filter(
    (rep) => rep.expand?.artiste?.id === id,
);

const firstRepresentation = representations[0];

// Construire la liste des scènes uniques à partir des représentations
const scenesMap = new Map();
for (const rep of representations) {
    const scene = rep.expand?.scene;
    if (!scene) continue;
    if (!scenesMap.has(scene.id)) {
        scenesMap.set(scene.id, scene);
    }
}
const scenes = Array.from(scenesMap.values());

const datesFormatees = representations.map((rep) => {
    const date = new Date(rep.date_heure);
    return {
        brut: rep.date_heure,
        label: date.toLocaleDateString("fr-FR", {
            weekday: "long",
            day: "numeric",
            month: "long",
            year: "numeric",
        }),
        heure: date.toLocaleTimeString("fr-FR", {
            hour: "2-digit",
            minute: "2-digit",
        }),
    };
});
---

<Layout>
    <!-- Hero artiste -->
    <section class="relative h-[35vh] md:h-[45vh]">
        <Image
            src={heroImage}
            alt={artiste?.nom || "Artiste"}
            class="absolute inset-0 w-full h-full object-cover"
            loading="eager"
        />
        <div
            class="absolute inset-0 bg-linear-to-t from-marron-fonce/70 to-transparent"
        >
        </div>
        <div class="absolute inset-0 flex items-end">
            <div class="container pb-10 md:pb-14">
                <h1
                    class="font-titre text-beige-claire text-3xl md:text-4xl lg:text-5xl tracking-wide drop-shadow-lg"
                >
                    {artiste?.nom || "Artiste"}
                </h1>
            </div>
        </div>
    </section>

    <section class="section bg-beige-claire">
        <div class="container">
            <div class="grid-12 gap-y-10 lg:gap-12">
                <!-- Colonne principale -->
                <div class="col-full lg:col-span-7 space-y-8">
                    <!-- Photo principale -->
                    <div
                        class="rounded-3xl overflow-hidden shadow-xl bg-marron-fonce/5"
                    >
                        {
                            artiste?.photo && (
                                <ImagePB
                                    record={artiste}
                                    field="photo"
                                    alt={artiste.nom}
                                    classPicture="w-full h-72 md:h-96 object-cover"
                                    thumb="1024x1024"
                                />
                            )
                        }
                    </div>

                    <!-- Description -->
                    {
                        artiste?.description && (
                            <div class="space-y-3">
                                <h2 class="font-corps font-bold text-marron-fonce text-xl md:text-2xl">
                                    À propos de l'artiste
                                </h2>
                                <div
                                    class="font-corps text-marron-fonce/90 leading-relaxed text-base md:text-lg prose max-w-none"
                                    set:html={artiste.description}
                                />
                            </div>
                        )
                    }

                    <!-- Galerie photo -->
                    {
                        Array.isArray(artiste?.galerie) &&
                            artiste.galerie.length > 0 && (
                                <div class="space-y-4">
                                    <h2 class="font-corps font-bold text-marron-fonce text-xl md:text-2xl">
                                        Galerie photo
                                    </h2>
                                    <div class="relative">
                                        <div class="flex gap-4 overflow-x-auto pb-2 snap-x snap-mandatory">
                                            {artiste.galerie.map((photo) => (
                                                <button
                                                    type="button"
                                                    class="min-w-[70%] md:min-w-[50%] lg:min-w-[40%] rounded-3xl overflow-hidden shadow-lg bg-marron-fonce/5 snap-start focus:outline-none focus-visible:ring-2 focus-visible:ring-or-vieilli"
                                                    data-full-src={`https://festicloze.rahmaproject.fr/api/files/artistes/${artiste.id}/${photo}`}
                                                >
                                                    <ImagePB
                                                        record={artiste}
                                                        field="galerie"
                                                        filename={photo}
                                                        alt={artiste.nom}
                                                        classPicture="w-full h-48 md:h-64 object-cover pointer-events-none"
                                                        thumb="1024x1024"
                                                    />
                                                </button>
                                            ))}
                                        </div>
                                    </div>
                                </div>
                            )
                    }
                </div>

                <!-- Colonne infos pratiques -->
                <aside class="col-full lg:col-span-5 space-y-8">
                    <!-- Dates de représentation -->
                    {
                        datesFormatees.length > 0 && (
                            <div class="bg-marron-fonce text-beige-claire rounded-3xl p-6 space-y-3 shadow-lg">
                                <h2 class="font-corps font-bold text-sous-titre text-lg md:text-xl uppercase tracking-wide">
                                    Dates de représentation
                                </h2>
                                <ul class="space-y-2 font-corps text-sm md:text-base">
                                    {datesFormatees.map((d) => (
                                        <li>
                                            <span class="block">{d.label}</span>
                                            <span class="block text-beige/80">
                                                {d.heure}
                                            </span>
                                        </li>
                                    ))}
                                </ul>
                            </div>
                        )
                    }

                    <!-- Scènes -->
                    {
                        scenes.length > 0 && (
                            <div class="bg-beige rounded-3xl p-6 space-y-3 shadow-md">
                                <h2 class="font-corps font-bold text-marron-fonce text-lg md:text-xl uppercase tracking-wide">
                                    Scènes
                                </h2>
                                <ul class="space-y-1 font-corps text-marron-fonce">
                                    {scenes.map((scene) => (
                                        <li>{scene.nom}</li>
                                    ))}
                                </ul>
                            </div>
                        )
                    }
                </aside>
            </div>
        </div>
    </section>

    <!-- Lightbox pour la galerie -->
    <div
        id="artist-lightbox"
        class="fixed inset-0 bg-black/80 z-40 items-center justify-center px-4 hidden"
    >
        <button
            type="button"
            id="artist-lightbox-close"
            class="absolute top-4 right-4 text-beige-claire text-3xl font-bold"
            aria-label="Fermer l'image en grand"
        >
            ×
        </button>
        <img
            id="artist-lightbox-img"
            src=""
            alt={artiste?.nom || "Photo grand format"}
            class="max-h-[90vh] max-w-full rounded-3xl shadow-2xl object-contain"
        />
    </div>
</Layout>

<script>
    const lightbox = document.getElementById("artist-lightbox");
    const lightboxImg = document.getElementById(
        "artist-lightbox-img",
    ) as HTMLImageElement | null;
    const lightboxClose = document.getElementById("artist-lightbox-close");

    const thumbs = document.querySelectorAll(
        "[data-full-src]",
    ) as NodeListOf<HTMLButtonElement>;

    function openLightbox(src: string) {
        if (!lightbox || !lightboxImg) return;
        lightboxImg.src = src;
        lightbox.classList.remove("hidden");
        lightbox.classList.add("flex");
    }

    function closeLightbox() {
        if (!lightbox || !lightboxImg) return;
        lightbox.classList.add("hidden");
        lightbox.classList.remove("flex");
        lightboxImg.src = "";
    }

    thumbs.forEach((btn) => {
        btn.addEventListener("click", () => {
            const src = btn.getAttribute("data-full-src");
            if (src) openLightbox(src);
        });
    });

    lightboxClose?.addEventListener("click", closeLightbox);
    lightbox?.addEventListener("click", (event) => {
        if (event.target === lightbox) {
            closeLightbox();
        }
    });
</script>
