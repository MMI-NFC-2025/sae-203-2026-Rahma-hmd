---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Card from "../components/Card.astro";
import { Image } from "astro:assets";

// Images pour les cards
import display1 from "../assets/images/image display.avif";
import display2 from "../assets/images/image display2.avif";
import display3 from "../assets/images/image display3.avif";
import display4 from "../assets/images/image display4.avif";

// Partenaires
import partenaire1 from "../assets/partenaire/2921.jpg";
import partenaire2 from "../assets/partenaire/6557.jpg";
import partenaire3 from "../assets/partenaire/images (3).png";
import partenaire4 from "../assets/partenaire/images (4).png";
import partenaire5 from "../assets/partenaire/Logo-regionCMJN-e1569509318692.webp";
import partenaire6 from "../assets/partenaire/logocm2018_carre_cmjn_72dpi__031211900_1028_11022019.jpg";
import partenaire7 from "../assets/partenaire/siege-social-1435217317.jpg";
import partenaire8 from "../assets/partenaire/unnamed.jpg";

const partenaires = [
	{ src: partenaire1, name: "Ville de Montbéliard" },
	{ src: partenaire2, name: "Pays de Montbéliard Agglomération" },
	{ src: partenaire3, name: "Région Bourgogne-Franche-Comté" },
	{ src: partenaire4, name: "MA Scène Nationale" },
	{ src: partenaire5, name: "Conservatoire du Pays de Montbéliard" },
	{ src: partenaire6, name: "France Bleu Belfort-Montbéliard" },
	{ src: partenaire7, name: "L'Est Républicain" },
	{ src: partenaire8, name: "Crédit Mutuel" },
];

const programmation = [
	{
		jour: "Jour 1",
		jourSemaine: "Samedi",
		date: "20/12",
		image: display1,
		titre: "L'Orfeo",
		sousTitre: "Il Giardino Armonico",
		description: "Aux origines de l'opéra",
	},
	{
		jour: "Jour 2",
		jourSemaine: "Dimanche",
		date: "21/12",
		image: display2,
		titre: "Armide",
		sousTitre: "Les Arts Florissants",
		description: "Sous le règne du Roi-Soleil",
	},
	{
		jour: "Jour 3",
		jourSemaine: "Lundi",
		date: "22/12",
		image: display3,
		titre: "Armide",
		sousTitre: "Les Talens Lyriques",
		description: "Passions et virtuosité",
	},
	{
		jour: "Jour 4",
		jourSemaine: "Mardi",
		date: "23/12",
		image: display4,
		titre: "Grand Final de Noël",
		sousTitre: "Il Seminario Musicale",
		description: "La fête baroque",
	},
];
---

<Layout>
	<!-- Hero Section -->
	<Hero />

	<!-- Billetterie -->
	<section class="section-sm bg-beige-claire text-center">
		<div class="container">
			<a href="/infos-pratiques" class="btn-primary font-bold px-10 py-3">
				Billeterie
			</a>
		</div>
	</section>

	<!-- Programmation -->
	<section class="section bg-beige-claire">
		<div class="container-wide">
			<!-- Titre + Bouton -->
			<div class="flex justify-center mb-8">
				<a
					href="/programme"
					class="inline-block border-2 border-marron-fonce text-marron-fonce font-corps px-8 py-2 rounded-full hover:bg-marron-fonce hover:text-beige-claire transition-colors"
				>
					Programmation
				</a>
			</div>

			<!-- Cards - Carousel en mobile, grille en desktop -->
			<div
				class="carousel-container overflow-x-auto pb-4 md:overflow-visible"
			>
				<div
					class="flex gap-6 md:grid md:grid-cols-2 lg:gap-8 min-w-max md:min-w-0"
				>
					{
						programmation.map((item) => (
							<div class="w-72 md:w-auto flex-shrink-0 md:flex-shrink">
								<Card
									jour={item.jour}
									jourSemaine={item.jourSemaine}
									date={item.date}
									image={item.image}
									titre={item.titre}
									sousTitre={item.sousTitre}
									description={item.description}
								/>
							</div>
						))
					}
				</div>
			</div>

			<!-- Bouton voir programme complet -->
			<div class="text-center mt-8">
				<a
					href="/programme"
					class="inline-block bg-rouge-accent text-beige-claire font-corps font-bold px-8 py-3 rounded-full hover:bg-marron-fonce transition-colors"
				>
					Voir le programme complet
				</a>
			</div>
		</div>
	</section>

	<!-- Infos pratiques -->
	<section class="section bg-beige">
		<div class="container-wide">
			<!-- Titre et description sur toute la largeur -->
			<h2 class="font-corps font-bold text-marron-fonce text-xl mb-4">
				Infos pratiques
			</h2>
			<p class="font-corps text-marron-fonce leading-relaxed mb-8">
				Le Festival Baroque de Noël vous accueille au Temple
				Saint-Martin de Montbéliard pour sa première édition. Venez
				découvrir quatre jours de concerts exceptionnels dans un cadre
				historique unique. Notre équipe met tout en œuvre pour vous
				offrir une expérience inoubliable, alliant musique, convivialité
				et magie de Noël.
			</p>

			<!-- Cards en dessous -->
			<div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4">
				<!-- Parking -->
				<div
					class="group bg-beige-claire rounded-2xl p-5 flex flex-col items-center text-center gap-3 shadow-sm hover:shadow-md hover:bg-or-vieilli/10 transition-all duration-300 cursor-default"
				>
					<div
						class="w-12 h-12 bg-marron-fonce rounded-full flex items-center justify-center group-hover:bg-or-vieilli group-hover:scale-110 transition-all duration-300"
					>
						<svg
							class="w-6 h-6 text-beige-claire"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M8 14v3m4-3v3m4-3v3M3 21h18M3 10h18M3 7l9-4 9 4M4 10h16v11H4V10z"
							></path>
						</svg>
					</div>
					<div>
						<h3
							class="font-corps font-bold text-marron-fonce text-sm mb-1"
						>
							Parking
						</h3>
						<p class="font-corps text-marron-fonce/70 text-xs">
							Gratuit à proximité
						</p>
					</div>
				</div>

				<!-- Vélo -->
				<div
					class="group bg-beige-claire rounded-2xl p-5 flex flex-col items-center text-center gap-3 shadow-sm hover:shadow-md hover:bg-or-vieilli/10 transition-all duration-300 cursor-default"
				>
					<div
						class="w-12 h-12 bg-marron-fonce rounded-full flex items-center justify-center group-hover:bg-or-vieilli group-hover:scale-110 transition-all duration-300"
					>
						<svg
							class="w-6 h-6 text-beige-claire"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M13 10V3L4 14h7v7l9-11h-7z"></path>
						</svg>
					</div>
					<div>
						<h3
							class="font-corps font-bold text-marron-fonce text-sm mb-1"
						>
							Espace vélo
						</h3>
						<p class="font-corps text-marron-fonce/70 text-xs">
							Stationnement sécurisé
						</p>
					</div>
				</div>

				<!-- Bar hivernal -->
				<div
					class="group bg-beige-claire rounded-2xl p-5 flex flex-col items-center text-center gap-3 shadow-sm hover:shadow-md hover:bg-or-vieilli/10 transition-all duration-300 cursor-default"
				>
					<div
						class="w-12 h-12 bg-marron-fonce rounded-full flex items-center justify-center group-hover:bg-or-vieilli group-hover:scale-110 transition-all duration-300"
					>
						<svg
							class="w-6 h-6 text-beige-claire"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
							></path>
						</svg>
					</div>
					<div>
						<h3
							class="font-corps font-bold text-marron-fonce text-sm mb-1"
						>
							Bar hivernal
						</h3>
						<p class="font-corps text-marron-fonce/70 text-xs">
							Douceurs locales
						</p>
					</div>
				</div>

				<!-- Animations -->
				<div
					class="group bg-beige-claire rounded-2xl p-5 flex flex-col items-center text-center gap-3 shadow-sm hover:shadow-md hover:bg-or-vieilli/10 transition-all duration-300 cursor-default"
				>
					<div
						class="w-12 h-12 bg-marron-fonce rounded-full flex items-center justify-center group-hover:bg-or-vieilli group-hover:scale-110 transition-all duration-300"
					>
						<svg
							class="w-6 h-6 text-beige-claire"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M9 19V6l12-3v13M9 19c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zm12-3c0 1.105-1.343 2-3 2s-3-.895-3-2 1.343-2 3-2 3 .895 3 2zM9 10l12-3"
							></path>
						</svg>
					</div>
					<div>
						<h3
							class="font-corps font-bold text-marron-fonce text-sm mb-1"
						>
							Animations
						</h3>
						<p class="font-corps text-marron-fonce/70 text-xs">
							Découverte du baroque
						</p>
					</div>
				</div>

				<!-- Boutique -->
				<div
					class="group bg-beige-claire rounded-2xl p-5 flex flex-col items-center text-center gap-3 shadow-sm hover:shadow-md hover:bg-or-vieilli/10 transition-all duration-300 cursor-default"
				>
					<div
						class="w-12 h-12 bg-marron-fonce rounded-full flex items-center justify-center group-hover:bg-or-vieilli group-hover:scale-110 transition-all duration-300"
					>
						<svg
							class="w-6 h-6 text-beige-claire"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"
							></path>
						</svg>
					</div>
					<div>
						<h3
							class="font-corps font-bold text-marron-fonce text-sm mb-1"
						>
							Boutique
						</h3>
						<p class="font-corps text-marron-fonce/70 text-xs">
							Souvenirs du festival
						</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	<!-- Nos Partenaires -->
	<section class="py-12 bg-beige-claire overflow-hidden">
		<div class="max-w-5xl mx-auto px-6">
			<h2 class="font-corps font-bold text-marron-fonce text-xl mb-8">
				Nos Partenaires
			</h2>
		</div>

		<!-- Carousel automatique -->
		<div class="partenaires-carousel">
			<div class="partenaires-track">
				{/* Premier set de logos */}
				{
					partenaires.map((partenaire) => (
						<div class="partenaire-item">
							<Image
								src={partenaire.src}
								alt={partenaire.name}
								width={120}
								height={80}
								class="object-contain max-h-16 w-auto grayscale hover:grayscale-0 transition-all duration-300"
							/>
						</div>
					))
				}
				{/* Duplication pour effet infini */}
				{
					partenaires.map((partenaire) => (
						<div class="partenaire-item">
							<Image
								src={partenaire.src}
								alt={partenaire.name}
								width={120}
								height={80}
								class="object-contain max-h-16 w-auto grayscale hover:grayscale-0 transition-all duration-300"
							/>
						</div>
					))
				}
			</div>
		</div>
	</section>
</Layout>

<style>
	/* Masquer la scrollbar mais garder le scroll */
	.carousel-container {
		-ms-overflow-style: none;
		scrollbar-width: none;
	}
	.carousel-container::-webkit-scrollbar {
		display: none;
	}

	/* Carousel partenaires automatique */
	.partenaires-carousel {
		width: 100%;
		overflow: hidden;
		padding: 1rem 0;
	}

	.partenaires-track {
		display: flex;
		gap: 3rem;
		animation: scroll-partners 30s linear infinite;
		width: max-content;
	}

	.partenaires-track:hover {
		animation-play-state: paused;
	}

	.partenaire-item {
		flex-shrink: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 0.5rem 1rem;
	}

	@keyframes scroll-partners {
		0% {
			transform: translateX(0);
		}
		100% {
			transform: translateX(-50%);
		}
	}
</style>
