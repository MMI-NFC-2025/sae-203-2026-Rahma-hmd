---
import Layout from "../../layouts/Layout.astro";
import { Image } from "astro:assets";
import {
    getSceneById,
    getRepresentations,
    getFileURL,
} from "../../../backend/backend.mjs";
import ImagePB from "../../components/ImagePB.astro";
import heroImage from "../../assets/images/festival.avif";

const { id } = Astro.params;

const scene = await getSceneById(id);

const allRepresentations = await getRepresentations();
const representations = allRepresentations.filter(
    (rep) => rep.expand?.scene?.id === id && rep.expand?.artiste,
);

const artistesParDate = representations.map((rep) => {
    const date = new Date(rep.date_heure);
    return {
        id: rep.expand.artiste.id,
        nom: rep.expand.artiste.nom,
        dateBrute: rep.date_heure,
        dateLabel: date.toLocaleDateString("fr-FR", {
            weekday: "long",
            day: "numeric",
            month: "long",
            year: "numeric",
        }),
        heureLabel: date.toLocaleTimeString("fr-FR", {
            hour: "2-digit",
            minute: "2-digit",
        }),
    };
});
---

<Layout>
    <!-- Hero scène -->
    <section class="relative h-[35vh] md:h-[45vh]">
        <Image
            src={heroImage}
            alt={scene?.nom || "Scène"}
            class="absolute inset-0 w-full h-full object-cover"
            loading="eager"
        />
        <div
            class="absolute inset-0 bg-gradient-to-t from-marron-fonce/70 to-transparent"
        >
        </div>
        <div class="absolute inset-0 flex items-end">
            <div class="container pb-10 md:pb-14">
                <h1
                    class="font-titre text-beige-claire text-3xl md:text-4xl lg:text-5xl tracking-wide drop-shadow-lg"
                >
                    {scene?.nom || "Scène"}
                </h1>
            </div>
        </div>
    </section>

    <section class="section bg-beige-claire">
        <div class="container">
            <div class="grid-12 gap-y-10 lg:gap-12">
                <!-- Colonne principale -->
                <div class="col-full lg:col-span-7 space-y-8">
                    <!-- Photo principale -->
                    <div
                        class="rounded-3xl overflow-hidden shadow-xl bg-marron-fonce/5"
                    >
                        {
                            scene?.photo && (
                                <ImagePB
                                    record={scene}
                                    field="photo"
                                    alt={scene.nom}
                                    classPicture="w-full h-72 md:h-96 object-cover"
                                    thumb="1024x1024"
                                />
                            )
                        }
                    </div>

                    <!-- Description / localisation / capacité -->
                    {
                        (scene?.description ||
                            scene?.localisation ||
                            scene?.capacite) && (
                            <div class="space-y-3">
                                {scene?.description && (
                                    <div
                                        class="font-corps text-marron-fonce/90 leading-relaxed text-base md:text-lg prose max-w-none"
                                        set:html={scene.description}
                                    ></div>
                                )}
                                {scene?.localisation && (
                                    <p class="font-corps text-marron-fonce/80 text-sm md:text-base">
                                        Localisation : {scene.localisation}
                                    </p>
                                )}
                                {scene?.capacite && (
                                    <p class="font-corps text-marron-fonce/80 text-sm md:text-base">
                                        Capacité : {scene.capacite} m²
                                    </p>
                                )}
                            </div>
                        )
                    }
                </div>

                <!-- Colonne artistes -->
                <aside class="col-full lg:col-span-5 space-y-8">
                    {
                        artistesParDate.length > 0 && (
                            <div class="bg-marron-fonce text-beige-claire rounded-3xl p-6 space-y-3 shadow-lg">
                                <h2 class="font-corps font-bold text-sous-titre text-lg md:text-xl uppercase tracking-wide">
                                    Artistes par date
                                </h2>
                                <ul class="space-y-3 font-corps text-sm md:text-base">
                                    {artistesParDate.map((item) => (
                                        <li class="flex flex-col">
                                            <a
                                                href={`/artistes/${item.id}`}
                                                class="font-medium hover:text-or-vieilli transition-colors"
                                            >
                                                {item.nom}
                                            </a>
                                            <span class="text-beige/80">
                                                {item.dateLabel} —{" "}
                                                {item.heureLabel}
                                            </span>
                                        </li>
                                    ))}
                                </ul>
                            </div>
                        )
                    }
                </aside>
            </div>
        </div>
    </section>
</Layout>
